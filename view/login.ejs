<!DOCTYPE html>
<html>
<head>
    <title>Admin Login</title>
    <link rel="stylesheet" href="/login.css">
</head>
<body>

<div class="login-container">

    <h1>⌚ SmartStore</h1>
    <h2>Admin Login</h2>

    <% if (error) { %>
        <p class="error-message"><%= error %></p>
    <% } %>

    <form action="/login" method="POST">

        <input
            type="email"
            name="email"
            placeholder="Enter Email"
            required>

        <input
            type="password"
            name="password"
            placeholder="Enter Password"
            required>

        <button type="submit">
            Login
        </button>

    </form>

</div>

</body>
</html>