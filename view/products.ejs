<!DOCTYPE html>
<html>
<head>
    <title>Products</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .products-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            padding: 20px 0;
            border-bottom: 2px solid var(--border);
        }

        .products-header h1 {
            margin: 0;
            color: var(--text);
        }

        .products-info {
            color: var(--muted);
            font-size: 16px;
        }

        .add-btn {
            display: inline-block;
            background: var(--primary);
            color: white;
            padding: 12px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

        .add-btn:hover {
            background: var(--primary-light);
            transform: translateY(-2px);
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
            margin-top: 30px;
        }

        .admin-product-card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(43, 124, 59, 0.08);
            transition: 0.3s;
        }

        .admin-product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(43, 124, 59, 0.15);
        }

        .admin-product-card img {
            width: 100%;
            height: 220px;
            object-fit: cover;
        }

        .admin-product-card h2 {
            padding: 16px;
            margin: 0;
            color: var(--text);
            font-size: 18px;
        }

        .admin-product-card p {
            padding: 0 16px 16px;
            margin: 0;
            font-weight: bold;
            color: var(--primary);
            font-size: 20px;
        }

        .card-actions {
            padding: 12px 16px;
            display: flex;
            gap: 10px;
            border-top: 1px solid var(--border);
        }

        .card-actions a {
            flex: 1;
            padding: 10px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: bold;
            text-align: center;
            transition: 0.3s;
            font-size: 14px;
        }

        .card-actions a:first-child {
            background: var(--primary);
            color: white;
        }

        .card-actions a:first-child:hover {
            background: var(--primary-light);
        }

        .card-actions a:last-child {
            background: #ffebee;
            color: #d32f2f;
        }

        .card-actions a:last-child:hover {
            background: #ffcdd2;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--muted);
        }

        .empty-state h2 {
            color: var(--text);
        }
    </style>
</head>
<body>

<div class="dashboard">
    <div class="products-header">
        <h1>Product Management</h1>
        <span class="products-info">Total products: <strong><%= products.length %></strong></span>
    </div>

    <a href="/products/new" class="add-btn">
        + Add New Product
    </a>

    <% if (products.length > 0) { %>
        <div class="product-grid">
            <% products.forEach(product => { %>
                <div class="admin-product-card">
                    <img src="<%= product.image %>" alt="<%= product.name %>">
                    <h2><%= product.name %></h2>
                    <p>TSH <%= product.price.toLocaleString() %></p>
                    <div class="card-actions">
                        <a href="/products/edit/<%= product.id %>">Edit</a>
                        <a href="/products/delete/<%= product.id %>" onclick="return confirm('Are you sure you want to delete this product?')">Delete</a>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="empty-state">
            <h2>No Products Yet</h2>
            <p>Start by adding your first product</p>
            <a href="/products/new" class="add-btn" style="margin-top: 20px;">+ Add Product</a>
        </div>
    <% } %>
</div>

</body>
</html>